  audioSource: {fileID: 1246928326}
  displayText: {fileID: 865864555}
  fullText: The Earth spins on its axis. This spinning is called rotation. Because
    the Earth rotates, different parts face the Sun and then move away from it. This
    causes day and night. As the Earth rotates, the Sun seems to move across the
    sky, and shadows change in length and direction during the day.
  timePerLetter: 0.05
  delayBetweenLines: 0.5
