  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ccab6104c16afe542b52fba61dddf931, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::AudioTextSync1
  audioSource: {fileID: 1246928326}
  displayText: {fileID: 6329745452972182561}
  fullText: In different seasons, the Sun appears higher or lower in the sky. In
    summer, the Sun is higher and shadows are shorter. In winter, the Sun is lower
    and shadows are longer. In spring and fall, the Sun is in between, so shadows
    are of medium length. Shadow length changes throughout the year.
  timePerLetter: 0.05
  delayBetweenLines: 0.5
  audioClip: {fileID: 8300000, guid: cd6ae94402013e74386f84fc6d90bb79, type: 3}
  actionButton: {fileID: 682934781}
  useButton: 1
