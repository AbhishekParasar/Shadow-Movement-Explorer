    - target: {fileID: 3770981849618022880, guid: 80b79820afb89ab4881f29906205b0e1, type: 3}
      propertyPath: m_text
      value: The Earth spins on its axis. One full spin takes 24 hours. This causes
        day and night.
      objectReference: {fileID: 0}
