  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::AudioTextSync1
  audioSource: {fileID: 1246928326}
  displayText: {fileID: 7325209461683307357}
  fullText: The Earth also moves around the Sun. This movement is called revolution.
    It takes 365 days for the Earth to complete one full revolution around the Sun.
    Because of this revolution and the tilt of the Earth, we have different seasons
    during the year.
  timePerLetter: 0.05
  delayBetweenLines: 0.5
  audioClip: {fileID: 8300000, guid: 906b831667fd1f949b2a4a4bbec96b84, type: 3}
